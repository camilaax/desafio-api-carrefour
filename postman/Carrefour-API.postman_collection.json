  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('runId')) {",
          "  pm.collectionVariables.set('runId', Date.now().toString());",
          "}",
          "",
          "if (!pm.collectionVariables.get('nonexistentUserId')) {",
          "  pm.collectionVariables.set('nonexistentUserId', '1234567890abcdef');",
          "}",
          "",
          "const jwtToken = pm.collectionVariables.get('jwtToken');",
          "if (jwtToken) {",
          "  pm.collectionVariables.set('authHeader', `Bearer ${jwtToken}`);",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "01 - Criar usuario admin para autenticacao",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const runId = pm.collectionVariables.get('runId');",
              "const adminEmail = `admin.${runId}@qa.com`;",
              "pm.collectionVariables.set('adminEmail', adminEmail);",
              "pm.collectionVariables.set('adminPassword', 'Teste@123');",
              "pm.collectionVariables.set('adminNome', `Admin ${runId}`);"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status de criacao valido', function () {",
              "  pm.expect([201, 400]).to.include(pm.response.code);",
              "});",
              "",
              "let json = {};",
              "try { json = pm.response.json(); } catch (e) {}",
              "",
              "pm.test('Resposta possui mensagem', function () {",
              "  pm.expect(json).to.have.property('message');",
              "  pm.expect(json.message).to.be.a('string').and.not.empty;",
              "});",
              "",
              "pm.test('Tempo de resposta aceitavel', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"nome\": \"{{adminNome}}\",\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\",\n  \"administrador\": \"true\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/usuarios",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "usuarios"
          ]
        }
      }
    },
    {
      "name": "02 - Login e captura de token",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status 200 no login', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "const tokenOrBearer = json.authorization || json.token;",
              "",
              "pm.test('Resposta contem token', function () {",
              "  pm.expect(tokenOrBearer).to.be.a('string').and.not.empty;",
              "});",
              "",
              "const normalized = tokenOrBearer.toLowerCase().startsWith('bearer ')",
              "  ? tokenOrBearer",
              "  : `Bearer ${tokenOrBearer}`;",
              "pm.collectionVariables.set('authHeader', normalized);",
              "pm.collectionVariables.set('jwtToken', normalized.replace(/^Bearer\\s+/i, ''));",
              "",
              "pm.test('Tempo de resposta aceitavel', function () {",
              "  pm.expect(pm.response.responseTime).to.be.below(3000);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{adminEmail}}\",\n  \"password\": \"{{adminPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "login"
          ]
        }
      }
    },
